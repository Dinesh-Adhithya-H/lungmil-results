# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Model artefacts (stored on lustre, not git) ───────────────────────────────
*.pt
*.pth
*.ckpt
*.npz
*.pkl

# ── SLURM logs ────────────────────────────────────────────────────────────────
*.out
*.err
slurm_logs/
job_scripts/

# ── Results (large binary outputs on lustre) ──────────────────────────────────
results_mm_abmil_*/
analysis_v6_*/
inference_cache_*
results/
# TCGA training output dirs (model checkpoints + large logs)
results_tcga_os_only/
results_gbmlgg_benchmark/
results_tcga_competitors/
# keep the aggregated benchmark table
!results_tcga_multitask/benchmark_table.json

# ── TensorBoard event files ───────────────────────────────────────────────────
events.out.tfevents.*

# ── Weights & Biases run logs ─────────────────────────────────────────────────
wandb/

# ── Interpretability outputs (large numpy/zarr outputs; keep source) ──────────
interpretability/slot_*/
interpretability/slot_shared_*/

# ── Visualization PNGs (regenerated from scripts) ────────────────────────────
visualizations/

# ── Patient explorer local data (large CSVs, regenerated by export scripts) ──
# Allow small summary files but ignore large per-sample CSVs
patient_explorer/data/*.csv
patient_explorer/data/*.npz
# keep JSON summaries and benchmark in git
!patient_explorer/data/benchmark_summary.csv
!patient_explorer/data/cohort_summary.json

# ── docs/ is tracked for GitHub Pages — do NOT add *.png exclusions here ─────
# docs/patients/ PNGs are committed intentionally

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
